# Copy values into your shell or a local untracked env file.
# Keep this pointed at a Discord bot that only has access to a test server first.
DISCORD_BOT_TOKEN=replace-me

# Optional runtime overrides for the local ingestion layer.
OPENCLAW_PRESENCE=busy
OPENCLAW_CONNECTION=connected
OPENCLAW_ACTIVITY=discord-ops
OPENCLAW_TASK_CURRENT=answering-discord-request
OPENCLAW_TASK_PHASE=gathering-context
OPENCLAW_HEARTBEAT_LAST_SEEN=2026-03-25T17:48:30Z
OPENCLAW_QUEUE_PENDING=2
OPENCLAW_QUEUE_BACKLOG=4
OPENCLAW_BLOCKERS_JSON=[{"code":"awaiting-human-review"}]
