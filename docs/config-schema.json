{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/openclaw-status-tracker/config-schema.json",
  "title": "OpenClaw Discord Bot Status Tracker Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["guild", "board"],
  "properties": {
    "guild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "discord": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["mock", "discord-rest"],
          "default": "mock"
        },
        "tokenEnvVar": { "type": "string", "minLength": 1, "default": "DISCORD_BOT_TOKEN" },
        "apiBaseUrl": { "type": "string", "minLength": 1, "default": "https://discord.com/api/v10" },
        "dryRun": { "type": "boolean", "default": true },
        "allowCreate": { "type": "boolean", "default": false },
        "testServerOnly": { "type": "boolean", "default": true },
        "maxOpsPerRun": { "type": "integer", "minimum": 0, "default": 5 },
        "requestDelayMs": { "type": "integer", "minimum": 0, "default": 750 }
      }
    },
    "board": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "baseName", "channels"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "baseName": { "type": "string", "minLength": 1 },
        "managedCategoryId": { "type": ["string", "null"], "minLength": 1 },
        "sortOffset": { "type": "integer", "default": 0 },
        "maxNameLength": { "type": "integer", "minimum": 10, "maximum": 100, "default": 60 },
        "channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "stateBinding", "template", "position"],
            "properties": {
              "id": { "type": ["string", "null"], "minLength": 1 },
              "key": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "stateBinding": {
                "type": "string",
                "enum": [
                  "presence",
                  "connection",
                  "activity",
                  "task.current",
                  "task.phase",
                  "heartbeat.lastSeen",
                  "heartbeat.age",
                  "queue.pending",
                  "queue.backlog",
                  "blockers.summary"
                ]
              },
              "template": { "type": "string", "minLength": 1 },
              "position": { "type": "integer", "minimum": 0, "description": "Relative position inside the board category" }
            }
          }
        }
      }
    },
    "runtime": {
      "$ref": "#/$defs/runtimeShape"
    },
    "runtimeSources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "snapshotFile": { "$ref": "#/$defs/fileSource" },
        "workspaceStateFile": { "$ref": "#/$defs/fileSource" },
        "heartbeatFile": { "$ref": "#/$defs/fileSource" },
        "queueFile": { "$ref": "#/$defs/fileSource" },
        "blockersFile": { "$ref": "#/$defs/fileSource" },
        "env": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "presence": { "type": "string", "minLength": 1 },
            "connection": { "type": "string", "minLength": 1 },
            "activity": { "type": "string", "minLength": 1 },
            "taskCurrent": { "type": "string", "minLength": 1 },
            "taskPhase": { "type": "string", "minLength": 1 },
            "heartbeatLastSeen": { "type": "string", "minLength": 1 },
            "queuePending": { "type": "string", "minLength": 1 },
            "queueBacklog": { "type": "string", "minLength": 1 },
            "blockersJson": { "type": "string", "minLength": 1 }
          }
        }
      }
    }
  },
  "anyOf": [
    { "required": ["runtime"] },
    { "required": ["runtimeSources"] }
  ],
  "$defs": {
    "fileSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "runtimeShape": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bot", "task", "heartbeat", "queue", "blockers"],
      "properties": {
        "bot": {
          "type": "object",
          "additionalProperties": false,
          "required": ["presence", "connection", "activity"],
          "properties": {
            "presence": {
              "type": "string",
              "enum": ["idle", "busy", "degraded", "offline"]
            },
            "connection": {
              "type": "string",
              "enum": ["connected", "reconnecting", "disconnected", "pairing"]
            },
            "activity": { "type": "string", "minLength": 1 }
          }
        },
        "task": {
          "type": "object",
          "additionalProperties": false,
          "required": ["current", "phase"],
          "properties": {
            "current": { "type": "string", "minLength": 1 },
            "phase": { "type": "string", "minLength": 1 }
          }
        },
        "heartbeat": {
          "type": "object",
          "additionalProperties": false,
          "required": ["lastSeen"],
          "properties": {
            "lastSeen": { "type": "string", "minLength": 1, "description": "ISO-8601 UTC timestamp of the bot's last heartbeat" }
          }
        },
        "queue": {
          "type": "object",
          "additionalProperties": false,
          "required": ["pending", "backlog"],
          "properties": {
            "pending": { "type": "integer", "minimum": 0 },
            "backlog": { "type": "integer", "minimum": 0 }
          }
        },
        "blockers": {
          "type": "array",
          "items": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "code": { "type": "string" },
                  "label": { "type": "string" },
                  "summary": { "type": "string" }
                }
              }
            ]
          }
        }
      }
    }
  }
}
