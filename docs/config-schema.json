{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/openclaw-status-tracker/config-schema.json",
  "title": "OpenClaw Status Tracker Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["guild", "board", "runtime"],
  "properties": {
    "guild": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 }
      }
    },
    "board": {
      "type": "object",
      "additionalProperties": false,
      "required": ["key", "baseName", "statusSource", "channels"],
      "properties": {
        "key": { "type": "string", "minLength": 1 },
        "baseName": { "type": "string", "minLength": 1 },
        "statusSource": {
          "type": "string",
          "enum": ["health", "tasks", "custom"]
        },
        "sortOffset": { "type": "integer", "default": 0 },
        "channels": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["key", "label", "metric", "template", "position"],
            "properties": {
              "key": { "type": "string", "minLength": 1 },
              "label": { "type": "string", "minLength": 1 },
              "metric": { "type": "string", "minLength": 1 },
              "template": { "type": "string", "minLength": 1 },
              "position": { "type": "integer", "minimum": 0, "description": "Relative position inside the board category" }
            }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["health", "metrics"],
      "properties": {
        "health": {
          "type": "object",
          "additionalProperties": false,
          "required": ["level", "emoji"],
          "properties": {
            "level": {
              "type": "string",
              "enum": ["green", "yellow", "red", "unknown"]
            },
            "emoji": { "type": "string", "minLength": 1 }
          }
        },
        "metrics": {
          "type": "object",
          "additionalProperties": {
            "type": ["string", "number", "integer"]
          }
        }
      }
    }
  }
}
